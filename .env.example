# ——— JWT 配置 ——————————————————————————————————————————
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ——— 数据库配置（开发用 SQLite，生产用 PostgreSQL）—————————————
# 直接设置 DATABASE_URL 优先于 POSTGRES_* 配置
# 示例 PostgreSQL: postgresql+asyncpg://postgres:secret@localhost:5432/deepagents
# 示例 SQLite:     sqlite+aiosqlite:///./fastapi_project.db
DATABASE_URL=sqlite+aiosqlite:///./fastapi_project.db

# PostgreSQL 配置（当 DATABASE_URL 未设置时使用）
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret
POSTGRES_DB=deepagents

# ——— OpenSandbox 沙箱配置 ——————————————————————————————
OPENSANDBOX_API_KEY=your_key_here
OPENSANDBOX_DOMAIN=api.opensandbox.io
OPENSANDBOX_IMAGE=ubuntu

# ——— SMTP 邮件配置（可选）—————————————————————————————————
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@example.com

# ——— Webhook 配置（可选）—————————————————————————————————
WEBHOOK_URL=https://your-webhook-endpoint.com/notify

# ——— 文件上传配置 ——————————————————————————————————————
UPLOAD_DIR=app/uploads
MAX_FILE_SIZE_MB=10

# ——— LangSmith LLM 追踪配置（可选）—————————————————————————
# 启用后所有 LLM 调用会记录到 LangSmith 对标 DeerFlow 的可观测性
LANGCHAIN_TRACING=false
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=deepagents
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ——— OpenTelemetry 链路追踪配置（可选）—————————————————————
OTEL_ENABLED=false
OTEL_SERVICE_NAME=deepagents
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
